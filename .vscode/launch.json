{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "WebApp",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-webapp",
      "program": "${workspaceFolder}/frontend/src/GrokInventoryAndTrend.WebApp/bin/Debug/net9.0/GrokInventoryAndTrend.WebApp.dll",
      "cwd": "${workspaceFolder}/frontend/src/GrokInventoryAndTrend.WebApp",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5147"
      }
    },
    {
      "name": "GrokInventoryAndTrend.Mcp",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-mcp",
      "program": "${workspaceFolder}/backend/GrokInventoryAndTrend.Mcp/bin/Debug/net9.0/GrokInventoryAndTrend.Mcp.dll",
      "cwd": "${workspaceFolder}/backend/GrokInventoryAndTrend.Mcp",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5040"
      },
      "envFile": "${workspaceFolder}/backend/GrokInventoryAndTrend.Api/.env.local"
    },
    {
      "name": "GrokInventoryAndTrend.Api",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/backend/GrokInventoryAndTrend.Api/bin/Debug/net9.0/GrokInventoryAndTrend.Api.dll",
      "cwd": "${workspaceFolder}/backend/GrokInventoryAndTrend.Api",
      "stopAtEntry": false,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5038"
      },
      "envFile": "${workspaceFolder}/backend/GrokInventoryAndTrend.Api/.env.local"
    }
  ],
  "compounds": [
    {
      "name": "API + MCP",
      "configurations": ["GrokInventoryAndTrend.Mcp", "GrokInventoryAndTrend.Api"],
      "stopAll": true,
      "preLaunchTask": "build-solution"
    }
  ]
}
