@page "/"
@rendermode InteractiveServer
@inject ScenarioPickerState PickerState
@inject RecentPlansListState RecentState
@inject PlanWorkspaceState WorkspaceState
@inject IPlanningApiClient ApiClient
@inject NavigationManager Navigation

<PageTransitionLoader Visible="_navigating" Blocking="true" Message="Opening plan workspace…" />

<PageMasthead Kicker="Supply chain planning"
                Title="Retail planning"
                Subtitle="Select a retail planning scenario and run the five-agent inventory pipeline." />

@if (!string.IsNullOrWhiteSpace(DisplayError))
{
    <ErrorState Message="@DisplayError" OnRetry="LoadAsync" />
}
else if (PickerState.IsLoading)
{
    <LoadingBlock Message="Loading planning scenarios…" />
}
else
{
    <PageSection Title="Planning scenarios" Subtitle="Search and filter demo scenarios backed by local seed data.">
        <ScenarioPickerPanel IsBusy="_starting" OnRun="StartSelectedScenario" />
    </PageSection>

    <RecentPlansList Plans="RecentState.Plans" OnOpen="OpenPlan" />
}

@code {
    private bool _starting;
    private bool _navigating;
    private string? _error;

    private string? DisplayError => _error ?? PickerState.Error;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        PickerState.OnChange += StateHasChanged;
        RecentState.OnChange += StateHasChanged;
        await LoadAsync();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (string.IsNullOrEmpty(Navigation.ToBaseRelativePath(e.Location)))
        {
            RecentState.Refresh();
        }

        _ = Task.Run(async () =>
        {
            await Task.Delay(250);
            await InvokeAsync(() =>
            {
                _navigating = false;
                StateHasChanged();
            });
        });
    }

    private async Task LoadAsync()
    {
        _error = null;
        await PickerState.LoadAsync();
        RecentState.Refresh();
    }

    private async Task StartSelectedScenario()
    {
        if (PickerState.SelectedScenario is null)
        {
            return;
        }

        _starting = true;
        _error = null;

        try
        {
            var plan = await ApiClient.CreatePlanAsync(PickerState.SelectedScenario.ScenarioId);
            RecentState.Refresh();
            await WorkspaceState.Reset();
            _navigating = true;
            Navigation.NavigateTo($"/plans/{plan.PlanId}");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _starting = false;
        }
    }

    private void OpenPlan(PlanSummary plan)
    {
        _navigating = true;
        Navigation.NavigateTo(string.IsNullOrWhiteSpace(plan.ExecutionId)
            ? $"/plans/{plan.PlanId}"
            : $"/plans/{plan.PlanId}/{plan.ExecutionId}");
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        PickerState.OnChange -= StateHasChanged;
        RecentState.OnChange -= StateHasChanged;
    }
}

@implements IDisposable
