@namespace GrokInventoryAndTrend.WebApp.Components.HumanReview

<div class="human-review-panel card">
    <h3 class="card__title">Human planner approval</h3>
    @if (ExistingDecision is not null)
    {
        <p class="human-review-panel__record">
            <strong>@ExistingDecision.Decision</strong> at @ExistingDecision.SubmittedAt.ToLocalTime().ToString("g")
        </p>
        @if (!string.IsNullOrWhiteSpace(ExistingDecision.Notes))
        {
            <p>@ExistingDecision.Notes</p>
        }
    }
    else if (CanSubmit)
    {
        <p>Review the replenishment plan and confirm whether orders should proceed.</p>
        <label class="field-label" for="reviewer-notes">Reviewer notes</label>
        <textarea id="reviewer-notes" class="input input--textarea" rows="3" @bind="Notes" @bind:event="oninput"></textarea>
        <div class="human-review-panel__actions">
            <LoadingButton IsLoading="IsBusy" CssClass="btn--success" OnClick="() => Submit(HumanDecisionType.Approve)">Approve plan</LoadingButton>
            <LoadingButton IsLoading="IsBusy" CssClass="btn--warning" Disabled="@string.IsNullOrWhiteSpace(Notes)" OnClick="() => Submit(HumanDecisionType.ApproveWithAdjustments)">Approve with adjustments</LoadingButton>
            <LoadingButton IsLoading="IsBusy" CssClass="btn--danger" OnClick="() => Submit(HumanDecisionType.Reject)">Reject</LoadingButton>
        </div>
    }
    else if (IsWaitingForPlannerReview)
    {
        <EmptyState Title="Waiting for planner copilot"
                    Description="Approval will be available once the planner copilot review finishes." />
    }
    else
    {
        <EmptyState Title="Approval not available" />
    }
</div>

@code {
    [Parameter] public bool CanSubmit { get; set; }
    [Parameter] public bool IsWaitingForPlannerReview { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public HumanDecisionRecord? ExistingDecision { get; set; }
    [Parameter] public EventCallback<(HumanDecisionType Decision, string Notes)> OnSubmit { get; set; }

    private string Notes { get; set; } = string.Empty;

    private Task Submit(HumanDecisionType decision) =>
        OnSubmit.InvokeAsync((decision, Notes));
}
