@namespace GrokInventoryAndTrend.WebApp.Components.Common

<button type="button" class="btn @CssClass" disabled="@(IsLoading || Disabled)" @onclick="OnClick">
    @if (IsLoading)
    {
        <span class="loading-block__spinner loading-block__spinner--inline" aria-hidden="true"></span>
        <span>@LoadingText</span>
    }
    else
    {
        @ChildContent
    }
</button>

@code {
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string LoadingText { get; set; } = "Working…";
    [Parameter] public string CssClass { get; set; } = "btn--primary";
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback<MouseEventArgs> OnClick { get; set; }
}
