@namespace Grok.InventoryAndTrend.WebApp.Components.Common

@if (Visible)
{
    <div class="page-transition @(Blocking ? "page-transition--blocking" : "page-transition--bar")" aria-live="polite">
        @if (Blocking)
        {
            <div class="page-transition__overlay">
                <span class="loading-block__spinner" aria-hidden="true"></span>
                <p>@Message</p>
            </div>
        }
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public bool Blocking { get; set; }
    [Parameter] public string Message { get; set; } = "Loading…";
}
