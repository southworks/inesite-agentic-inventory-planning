@namespace Cohere.InventoryAndTrend.WebApp.Components.Layout
@rendermode InteractiveServer
@inject NavigationManager Navigation

<header class="top-bar">
    <div class="top-bar__inner app-container">
        <a href="/" class="brand" @onclick="GoHome" @onclick:preventDefault>
            <span class="brand__mark" aria-hidden="true">CIT</span>
            <span class="brand__text">
                <span class="brand__name">Cohere Inventory &amp; Trend</span>
                <span class="brand__tagline">Plan smarter. Stock right.</span>
            </span>
        </a>
        <nav class="top-bar__nav">
            <a href="/" class="top-bar__link" @onclick="GoHome" @onclick:preventDefault>Home</a>
        </nav>
    </div>
</header>

@code {
    private void GoHome() => Navigation.NavigateTo("/");
}
