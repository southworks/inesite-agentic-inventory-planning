@namespace Cohere.InventoryAndTrend.WebApp.Components.Plans

<PageSection Title="Active plans" Subtitle="Workflow runs started in this session.">
    @if (Plans.Count == 0)
    {
        <EmptyState Title="No active plans" Description="Start a workflow from a scenario above to see runs here." />
    }
    else
    {
        <div class="recent-plans">
            @foreach (var plan in Plans)
            {
                <RecentPlanRow Plan="plan" OnOpen="OnOpen" />
            }
        </div>
    }
</PageSection>

@code {
    [Parameter] public IReadOnlyList<PlanSummary> Plans { get; set; } = [];
    [Parameter] public EventCallback<PlanSummary> OnOpen { get; set; }
}
