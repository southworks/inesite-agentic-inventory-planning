@namespace Cohere.InventoryAndTrend.WebApp.Components.Agents

<div class="agent-panel card">
    <div class="agent-panel__header">
        <span class="agent-panel__role">@Role</span>
        <StatusBadge Label="@Decision" CssClass="status-badge--info" />
    </div>
    <p class="agent-panel__summary">@Summary</p>
    <details class="agent-panel__evidence">
        <summary>Evidence</summary>
        <p>@Evidence</p>
    </details>
    @if (ChildContent is not null)
    {
        <div class="agent-panel__body">@ChildContent</div>
    }
</div>

@code {
    [Parameter] public string Role { get; set; } = "Agent";
    [Parameter] public string Summary { get; set; } = string.Empty;
    [Parameter] public string Decision { get; set; } = string.Empty;
    [Parameter] public string Evidence { get; set; } = string.Empty;
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
