@namespace GrokInventoryAndTrend.WebApp.Components.Agents

@if (Result is FeatureCausalityStageResult feature)
{
    <AgentPanel Role="Feature &amp; causality" Summary="@feature.Summary" Decision="@feature.Decision" Evidence="@feature.Evidence">
        @if (feature.TopDrivers.Count > 0)
        {
            <h4 class="agent-panel__subtitle">Top demand drivers</h4>
            <ul class="chip-list">@foreach (var d in feature.TopDrivers) { <li>@d</li> }</ul>
        }
        @if (feature.ElasticityNotes.Count > 0)
        {
            <h4 class="agent-panel__subtitle">Elasticity notes</h4>
            <ul class="chip-list">@foreach (var n in feature.ElasticityNotes) { <li>@n</li> }</ul>
        }
    </AgentPanel>
}
else if (Result is not null)
{
    <AgentPanel Role="Feature &amp; causality" Summary="@Result.Summary" Decision="@Result.Decision" Evidence="@Result.Evidence" />
}

@code {
    [Parameter] public AgentStageResult? Result { get; set; }
}
